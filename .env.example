# Lupo - environment template. Copy to .env and fill in.
# Everything blank / all toggles 0  =>  fully offline, deterministic demo.
# Each real path falls back to the stub on any error, so a missing/typo key
# can never crash the demo.

# ----------------------------------------------------------------------------
# Scenario + human channel
# ----------------------------------------------------------------------------
LUPO_SCENARIO=brunch                 # brunch | tomorrowland
LUPO_HUMAN_CHANNEL=scripted          # scripted | web | voice | whatsapp
                                     # web   -> tap approve/amend/confirm on the canvas
                                     # voice -> speak each ping via Gemini TTS, confirm on the panel

# ----------------------------------------------------------------------------
# Google AI Studio (Gemini) - https://aistudio.google.com/
# Powers: stylist spec, extraction escalation, (optional) photo vision, voice TTS.
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
USE_REAL_GEMINI=0                    # 1 -> stylist spec + extraction escalation via Gemini
USE_REAL_VISION=0                    # 1 -> judge listing photos with Gemini multimodal (slower)
USE_REAL_VOICE=0                     # 1 -> speak human pings aloud via Gemini TTS
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
# GOOGLE_API_KEY=                    # alias some SDKs read; mirror GEMINI_API_KEY if needed

# ----------------------------------------------------------------------------
# Fastino Pioneer (GLiNER2 hosted inference + LoRA finetune) - https://pioneer.ai/
# Powers: multilingual material/style/fit extraction (cheap model) + the finetune story.
# ----------------------------------------------------------------------------
PIONEER_API_KEY=
USE_PIONEER=0                        # 1 -> route extraction to Pioneer hosted GLiNER2 /inference
PIONEER_API_BASE=https://api.pioneer.ai
PIONEER_BASE_MODEL=fastino/gliner2-base-v1
PIONEER_TRAINED_MODEL_ID=           # set to your LoRA job id after running scripts/pioneer_finetune.py
PIONEER_DATASET_NAME=lupo-attrs-v1

# Local GLiNER (alternative to Pioneer; pulls torch, slow first run). Leave 0 if using Pioneer.
USE_REAL_GLINER=0
GLINER_MODEL=urchade/gliner_multi-v2.1
GLINER_ESCALATION_THRESHOLD=0.55     # below this confidence, escalate the listing to Gemini

# ----------------------------------------------------------------------------
# fal.ai (outfit preview image) - https://fal.ai/
# Powers: a generic-model outfit preview rendered when the stylist proposes the
# vision, regenerated when you amend it. No user photo needed.
# ----------------------------------------------------------------------------
FAL_KEY=
USE_REAL_FAL=0
FAL_IMAGE_MODEL=fal-ai/flux/schnell  # fast text-to-image; swap for a higher-fidelity model if time allows

# ----------------------------------------------------------------------------
# Vinted (live search). Reuses the vinted_agent token-hack.
# Grab from a logged-in browser: DevTools > Application > Cookies > _vinted_fr_session.
# If the catalog endpoint 401s, also paste the Authorization Bearer token.
# ----------------------------------------------------------------------------
LUPO_VINTED_LIVE=0                   # 1 -> call the real Vinted API and cache; else replay fixtures
VINTED_DOMAIN=fr                     # fr | be | de | com ...
VINTED_SESSION_COOKIE=
VINTED_BEARER_TOKEN=                 # optional; add if you hit 401 with cookie-only

# ----------------------------------------------------------------------------
# Twilio WhatsApp (optional; only if LUPO_HUMAN_CHANNEL=whatsapp)
# ----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WHATSAPP_TO=
